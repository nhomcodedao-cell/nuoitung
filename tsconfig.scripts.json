{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist-scripts",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "typeRoots": ["./node_modules/@types"]
  },
  "include": [
    "hooks/**/*",
    "scripts/**/*",
    "lib/**/*",
    "model/**/*",
    "next-env.d.ts",
    "**/*.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
